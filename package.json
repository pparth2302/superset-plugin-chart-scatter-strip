{
  "name": "@pparth2302/superset-plugin-chart-scatter-strip",
  "version": "0.1.5",
  "description": "A custom Apache Superset plugin that renders scatter plots as a 1xN strip of small multiples using ECharts.",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "esm/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "esm",
    "lib"
  ],
  "private": false,
  "scripts": {
    "build": "npm run build-cjs && npm run build-esm && npm run ts-types",
    "build-cjs": "babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir lib",
    "build-clean": "npm run clean && npm run build",
    "build-esm": "cross-env BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --copy-files --out-dir esm",
    "dev": "cross-env BABEL_OUTPUT=esm babel src --extensions \".ts,.tsx,.js,.jsx\" --watch --copy-files --out-dir esm",
    "prebuild": "rimraf {lib,esm,tsconfig.tsbuildinfo}",
    "postbuild": "npm run test",
    "preview": "node scripts/preview-server.mjs",
    "ts-types": "tsc --build",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pparth2302/superset-plugin-chart-scatter-strip.git"
  },
  "homepage": "https://github.com/pparth2302/superset-plugin-chart-scatter-strip#readme",
  "bugs": {
    "url": "https://github.com/pparth2302/superset-plugin-chart-scatter-strip/issues"
  },
  "keywords": [
    "superset",
    "apache-superset",
    "plugin",
    "echarts",
    "scatter",
    "small-multiples",
    "visualization"
  ],
  "author": "Parth Patel",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "echarts": "^6.0.0"
  },
  "peerDependencies": {
    "@superset-ui/chart-controls": "*",
    "@superset-ui/core": "*",
    "react": "^17.0.2"
  },
  "devDependencies": {
    "@airbnb/config-babel": "^2.0.1",
    "@babel/cli": "^7.16.0",
    "@types/jest": "^26.0.4",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.1.2"
  }
}
